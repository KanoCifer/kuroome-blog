# 数据库配置
DATABASE_URL='postgresql+asyncpg://user:password@localhost/dbname'
DB_MIGRATE_URL='postgresql+psycopg://user:password@localhost/dbname'

# 邮件配置
MAIL_USERNAME="your-email@example.com"
MAIL_PASSWORD="your-email-password"

# 安全配置
SECRET_KEY='your-secret-key-here'
CSRF_COOKIE_SECURE=False

# MongoDB配置
MONGO_URI="mongodb://localhost:27017/"

# AI API配置
API_KEY="your-ai-api-key"

# WebAuthn配置
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5173

# GitHub OAuth配置
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:5555/api/v1/auth/github/callback

# Webhook配置
WEBHOOK_SECRET=your-strong-webhook-secret-here  # Gitee Webhook验证密钥

# Amap地图配置
AMAP_SECURITY_CODE=your-amap-security-code-here
