{
  "name": "frontend",
  "version": "3.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm run type-check && pnpm run build-only --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint src --fix",
    "lint:eslint": "eslint src . --fix --cache",
    "format": "pnpm exec prettier ./src --write",
    "build:css": "tailwindcss -i ./src/assets/base.css -o ./src/assets/main.css --minify",
    "watch:css": "tailwindcss -i ./src/assets/base.css -o ./src/assets/main.css --watch",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "@lucide/vue": "^1.17.0",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@simplewebauthn/browser": "^13.3.0",
    "@tailwindcss/cli": "^4.3.0",
    "@types/markdown-it": "^14.1.2",
    "@unhead/vue": "^3.1.4",
    "@vueuse/core": "^14.3.0",
    "@vueuse/head": "^2.0.0",
    "animate.css": "^4.1.1",
    "axios": "^1.17.0",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "dompurify": "^3.4.9",
    "echarts": "^6.1.0",
    "github-markdown-css": "^5.9.0",
    "highlight.js": "^11.11.1",
    "lottie-web": "5.13.0",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.17.0",
    "markdown-it": "^14.2.0",
    "marked": "^18.0.5",
    "mitt": "^3.0.1",
    "motion-v": "^2.3.0",
    "pace-js": "^1.2.4",
    "pinia": "^3.0.4",
    "prosemirror-markdown": "^1.13.4",
    "qweather-icons": "^1.8.0",
    "radix-ui": "^1.5.0",
    "reka-ui": "^2.9.10",
    "shadcn": "^4.11.0",
    "shadcn-vue": "^2.7.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "turndown": "^7.2.4",
    "twikoo": "^1.7.11",
    "ua-parser-js": "^2.0.10",
    "unhead": "^3.1.4",
    "uuid": "^13.0.2",
    "vite-ssg": "^28.3.0",
    "vue": "^3.5.38",
    "vue-draggable-plus": "^0.6.1",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.1.0",
    "vue3-lottie": "^3.3.1",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.3",
    "@types/swagger-ui": "^5.32.0",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/eslint-plugin": "^1.6.20",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.57.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.57.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "sass-embedded": "^1.100.0",
    "terser": "^5.48.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.4"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
