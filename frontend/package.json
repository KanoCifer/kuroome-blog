{
  "name": "frontend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "run-p dev:vite watch:css",
    "dev:vite": "vite",
    "build": "run-s build:css type-check \"build-only {@}\" --",
    "build:ssg": "run-s build:css type-check \"build-ssg {@}\" --",
    "preview": "vite preview",
    "preview:ssg": "vite-ssg preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "generate-sitemap": "node generate-sitemap.js",
    "build-ssg": "npm run generate-sitemap && SSG_BUILD=true vite-ssg build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "build:css": "tailwindcss -i ./src/assets/base.css -o ./src/assets/main.css --minify",
    "watch:css": "tailwindcss -i ./src/assets/base.css -o ./src/assets/main.css --watch"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@tailwindcss/cli": "^4.2.1",
    "@tiptap/extension-bubble-menu": "^3.20.0",
    "@tiptap/extension-code-block-lowlight": "^3.20.0",
    "@tiptap/extension-collaboration": "^3.20.0",
    "@tiptap/extension-drag-handle": "^3.20.0",
    "@tiptap/extension-drag-handle-vue-3": "^3.20.0",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-list": "^3.20.0",
    "@tiptap/extension-node-range": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/extension-table": "^3.20.0",
    "@tiptap/extension-table-cell": "^3.20.0",
    "@tiptap/extension-table-header": "^3.20.0",
    "@tiptap/extension-table-row": "^3.20.0",
    "@tiptap/extension-task-item": "^3.20.0",
    "@tiptap/extension-task-list": "^3.20.0",
    "@tiptap/extension-text-align": "^3.20.0",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/extensions": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@tiptap/vue-3": "^3.20.0",
    "@tiptap/y-tiptap": "^3.0.2",
    "@types/markdown-it": "^14.1.2",
    "@unhead/vue": "^2.1.6",
    "@vueuse/core": "^14.2.1",
    "@vueuse/head": "^2.0.0",
    "animate.css": "^4.1.1",
    "axios": "^1.13.5",
    "dayjs": "^1.11.19",
    "highlight.js": "^11.11.1",
    "lowlight": "^3.3.0",
    "markdown-it": "^14.1.1",
    "mitt": "^3.0.1",
    "pace-js": "^1.2.4",
    "pinia": "^3.0.4",
    "prosemirror-markdown": "^1.13.4",
    "tailwindcss": "^4.2.1",
    "tiptap-markdown": "^0.9.0",
    "unhead": "^2.1.6",
    "vite-ssg": "^28.3.0",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3",
    "vue3-lottie": "^3.3.1",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.3.0",
    "@types/swagger-ui": "^5.21.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.50.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^28.1.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.50.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
