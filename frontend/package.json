{
  "name": "frontend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "run-p dev:vite watch:css",
    "dev:vite": "vite",
    "build": "run-s build:css type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint src --fix",
    "lint:eslint": "eslint src . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "build:css": "tailwindcss -i ./src/assets/base.css -o ./src/assets/main.css --minify",
    "watch:css": "tailwindcss -i ./src/assets/base.css -o ./src/assets/main.css --watch"
  },
